    "superpowers:verification-before-completion": "on",
    "superpowers:finishing-a-development-branch": "on",
    "init": "on",
    "superpowers:writing-plans": "on",
    "superpowers:executing-plans": "on",
    "superpowers:requesting-code-review": "on",
    "graphify": "on"
  }
