# Playwright test credentials.
#
# Copy this file to .env and fill in real values:
#
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials. Once it exists, the suite
# runs with a bare `npx playwright test`, with no env vars on the command line.
#
# Anything already set in the environment wins over this file, so CI can inject
# these as secrets without a .env present.

# Base URL of the WordPress install to test against.
# The suite SKIPS every admin test while this contains "placeholder", so the
# default is a safe no-op rather than a failure.
PLAYWRIGHT_BASE_URL=https://staging.placeholder.blueworx.io

# An administrator on that site. Without both of these the admin specs skip.
WP_ADMIN_USER=
WP_ADMIN_PASS=

# Slug of the login form. The plugin's `login` feature moves the form off
# wp-login.php and blocks the default path, so this must match the site.
# Give the slug WITHOUT a leading slash.
WP_LOGIN_PATH=admin_login
